# VigiParl — Variables d'environnement
# Copiez ce fichier en .env.local pour le développement
# Ajoutez ces variables dans Vercel pour la production

# ─── Supabase ───────────────────────────────────────────────────────────────────
# Trouvez ces valeurs dans https://app.supabase.com/project/pmnlfzwfolqeoxaottit/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://pmnlfzwfolqeoxaottit.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...    # anon / public key
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # ⚠️ À RÉGÉNÉRER (l'ancienne a été exposée)

# ─── Resend (envoi d'emails) ─────────────────────────────────────────────────────
# 1. Créez un compte sur https://resend.com
# 2. Ajoutez le domaine cavaparlement.eu et vérifiez les DNS
# 3. Créez une clé API
RESEND_API_KEY=re_...

# Emails institutions acceptés :
# @clb-an.fr           → collaborateurs AN actifs
# @clb-senat.fr        → collaborateurs Sénat actifs
# @europarl.europa.eu  → collaborateurs PE actifs
# tout email valide    → anciens collaborateurs
